/ {
	solenoids {
		compatible = "gpio-leds";
		solenoid0: solenoid_0 {
			/* Physical Solenoid on Pin P0.13 */
			gpios = <&gpio0 13 GPIO_ACTIVE_HIGH>;
			label = "Solenoid 0";
		};
	};

	aliases {
		/* Point solenoid to external Pin P0.13 */
		solenoid = &solenoid0;
	};
};

